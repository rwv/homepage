---
import '@/styles/global.css'
import type { Lang } from '@/i18n/ui'
import { useTranslations, getLocalizedPath } from '@/i18n/utils'
import { defaultLang } from '@/i18n/ui'
import { ClientRouter } from 'astro:transitions'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const currentPath =
  lang === defaultLang ? Astro.url.pathname : Astro.url.pathname.replace(`/${lang}`, '') || '/'
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t('site.name')}</title>
    <meta name="description" content={t('site.description')} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#181818" media="(prefers-color-scheme: dark)" />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="en" href={new URL(currentPath, Astro.site).href} />
    <link rel="alternate" hreflang="zh" href={new URL(`/zh${currentPath}`, Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(currentPath, Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={t('site.name')} />
    <meta property="og:description" content={t('site.description')} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_CN'} />
    <meta property="og:site_name" content={t('site.name')} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={t('site.name')} />
    <meta name="twitter:description" content={t('site.description')} />

    <ClientRouter />
  </head>
  <body>
    <div class="mx-auto max-w-5xl p-8 lg:grid lg:grid-cols-[1fr_3fr] lg:p-0 lg:px-8">
      <header class="max-h-screen leading-relaxed lg:flex lg:items-center lg:pr-20">
        <div class="lg:flex lg:flex-wrap lg:items-start">
          <div class="text-center lg:text-left">
            <h1 class="relative -top-2.5 text-[2rem] font-medium">{t('site.name')}</h1>
          </div>
        </div>
      </header>
      <main transition:animate="none">
        <slot />
      </main>
    </div>

    <!-- Auto-detect language and redirect -->
    <script is:inline data-astro-rerun>
      ;(function () {
        if (
          window.location.pathname === '/' &&
          navigator.language &&
          navigator.language.startsWith('zh')
        ) {
          window.location.replace('/zh/')
        }
      })()
    </script>
  </body>
</html>

<style>
  @media (min-width: 1024px) {
    body {
      display: flex;
      place-items: center;
    }
  }
</style>
