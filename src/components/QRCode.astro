---
import QRCodeLib from 'qrcode'

interface Props {
  value: string
  width?: number
  dark?: string
  light?: string
}

const { value, width = 200, dark = '#2c3e50', light = '#ffffff' } = Astro.props

const svg = await QRCodeLib.toString(value, {
  type: 'svg',
  width,
  color: { dark, light },
  margin: 2
})
---

<Fragment set:html={svg} />
